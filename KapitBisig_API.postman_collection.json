					}
				},
				{
					"name": "Update NGO Profile",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/ngos/1", "host": ["{{base_url}}"], "path": ["ngos", "1"] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Bayanihan Foundation Updated\",\n  \"description\": \"Updated description.\",\n  \"websiteUrl\": \"https://bayanihan.org\",\n  \"phoneNumber\": \"+639179999999\",\n  \"address\": \"456 Bonifacio St, Quezon City\",\n  \"logoUrl\": \"\"\n}"
						}
					}
				},
				{
					"name": "Delete NGO Profile",
					"request": {
						"method": "DELETE",
						"url": { "raw": "{{base_url}}/ngos/1", "host": ["{{base_url}}"], "path": ["ngos", "1"] }
					}
				},
				{
					"name": "Get Pending Verifications (Admin)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/ngos/verification/pending?limit=50&offset=0",
							"host": ["{{base_url}}"],
							"path": ["ngos", "verification", "pending"],
							"query": [
								{ "key": "limit", "value": "50" },
								{ "key": "offset", "value": "0" }
							]
						}
					}
				},
				{
					"name": "Verify NGO (Admin)",
					"request": {
						"method": "POST",
						"url": { "raw": "{{base_url}}/ngos/1/verify", "host": ["{{base_url}}"], "path": ["ngos", "1", "verify"] }
					}
				},
				{
					"name": "Reject NGO (Admin)",
					"request": {
						"method": "POST",
						"url": { "raw": "{{base_url}}/ngos/1/reject", "host": ["{{base_url}}"], "path": ["ngos", "1", "reject"] }
					}
				}
			]
		},
