{
	"info": {
		"name": "KapitBisig API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5001"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Sign Up",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/auth/signup", "host": ["{{base_url}}"], "path": ["auth", "signup"] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Juan\",\n  \"lastName\": \"dela Cruz\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Sign In",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/auth/signin", "host": ["{{base_url}}"], "path": ["auth", "signin"] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"juan@example.com\",\n  \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
					}
				},
				{
					"name": "Google OAuth (Not Implemented)",
					"request": {
						"method": "GET",
						"url": { "raw": "{{base_url}}/auth/google", "host": ["{{base_url}}"], "path": ["auth", "google"] }
					}
				},
				{
					"name": "Facebook OAuth (Not Implemented)",
					"request": {
						"method": "GET",
						"url": { "raw": "{{base_url}}/auth/facebook", "host": ["{{base_url}}"], "path": ["auth", "facebook"] }
					}
				}
			]
		},
		{
			"name": "Campaigns",
			"item": [
				{
					"name": "Create Campaign",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/campaigns", "host": ["{{base_url}}"], "path": ["campaigns"] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Help Typhoon Victims\",\n  \"description\": \"Raising funds for typhoon victims in Visayas.\",\n  \"category\": \"disaster_relief\",\n  \"targetAmount\": 50000,\n  \"ngoId\": \"1\",\n  \"imageUrl\": \"\"\n}"
						}
					}
				},
				{
					"name": "Get All Campaigns",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/campaigns?status=active&limit=50&offset=0",
							"host": ["{{base_url}}"],
							"path": ["campaigns"],
							"query": [
								{ "key": "status", "value": "active", "disabled": true },
								{ "key": "category", "value": "disaster_relief", "disabled": true },
								{ "key": "search", "value": "", "disabled": true },
								{ "key": "limit", "value": "50" },
								{ "key": "offset", "value": "0" }
							]
						}
					}
				},
				{
					"name": "Get Campaign by ID",
					"request": {
						"method": "GET",
						"url": { "raw": "{{base_url}}/campaigns/1", "host": ["{{base_url}}"], "path": ["campaigns", "1"] }
					}
				},
				{
					"name": "Update Campaign",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/campaigns/1", "host": ["{{base_url}}"], "path": ["campaigns", "1"] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated Campaign Title\",\n  \"description\": \"Updated description.\",\n  \"targetAmount\": 75000,\n  \"status\": \"active\",\n  \"imageUrl\": \"\",\n  \"startDate\": \"2026-05-18T00:00:00.000Z\",\n  \"endDate\": \"2026-12-31T00:00:00.000Z\"\n}"
						}
					}
				},
				{
					"name": "Submit Campaign for Approval",
					"request": {
						"method": "POST",
						"url": { "raw": "{{base_url}}/campaigns/1/submit", "host": ["{{base_url}}"], "path": ["campaigns", "1", "submit"] }
					}
				},
				{
					"name": "Approve Campaign (Admin)",
					"request": {
						"method": "POST",
						"url": { "raw": "{{base_url}}/campaigns/1/approve", "host": ["{{base_url}}"], "path": ["campaigns", "1", "approve"] }
					}
				},
				{
					"name": "Reject Campaign (Admin)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": { "raw": "{{base_url}}/campaigns/1/reject", "host": ["{{base_url}}"], "path": ["campaigns", "1", "reject"] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"Insufficient documentation provided.\"\n}"
						}
					}
				},
				{
					"name": "Delete Campaign",
					"request": {
						"method": "DELETE",
						"url": { "raw": "{{base_url}}/campaigns/1", "host": ["{{base_url}}"], "path": ["campaigns", "1"] }
					}
				}
			]
		},
		{
			"name": "NGOs",
			"item": [
				{
					"name": "Create NGO Profile",
